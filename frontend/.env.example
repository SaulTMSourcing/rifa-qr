# ============================================================
# Frontend - Configuracion de entorno (Vite)
# ============================================================
# Las variables deben empezar con VITE_ para que Vite las
# exponga al navegador. NO meter secretos aqui: estas variables
# terminan visibles en el bundle JS del cliente.
# ============================================================

# URL base del backend. En desarrollo apunta al Node local.
# En produccion se cambia a la URL real del API en Hostinger.
VITE_API_URL=http://localhost:3001
