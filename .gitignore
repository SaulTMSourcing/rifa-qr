# ============================================================
# Dependencias
# ============================================================
node_modules/
backend/node_modules/
frontend/node_modules/

# ============================================================
# Variables de entorno (CRITICO: nunca subir a Git)
# ============================================================
.env
.env.local
.env.*.local
backend/.env
frontend/.env

# Sí permitimos los .env.example (plantilla sin secretos)
!.env.example
!backend/.env.example
!frontend/.env.example

# ============================================================
# Build outputs
# ============================================================
backend/dist/
frontend/dist/
frontend/build/

# ============================================================
